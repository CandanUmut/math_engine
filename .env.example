# PRU Math Engine — environment configuration

# Path to the SQLite database file. Relative paths resolve from the repo root.
PRU_DB_PATH=./data/pru_math.sqlite

# Path to the persisted relational graph (NetworkX gpickle).
PRU_GRAPH_PATH=./data/pru_graph.gpickle

# Similarity threshold (0..1). Edges with score below this are not stored.
# Higher = sparser graph, faster queries; lower = denser, more recall.
PRU_SIM_THRESHOLD=0.55

# Default number of similar-problem neighbours surfaced in the trace.
PRU_SIMILAR_TOP_K=5

# Phase 3: maximum number of approaches the reasoner will try per problem
# before giving up. Each attempt is persisted as a learning signal.
PRU_MAX_ATTEMPTS=3

# UCB1 exploration constant. Higher = more exploration of unseen approaches.
PRU_LEARNER_EXPLORATION=1.0

# Phase 4: when a chosen attempt verifies, also call a *different* tool
# to cross-check the answer. Slower but higher confidence.
PRU_CROSS_VERIFY=false

# Optional: Wolfram Alpha API key. If unset, the Wolfram tool is
# registered as unavailable and never selected.
# WOLFRAM_APP_ID=

# Phase 6: path to the runtime settings JSON. Layered on top of the
# env-loaded defaults; writable via PUT /config or the cog icon in the UI.
# PRU_SETTINGS_PATH=./data/settings.json

# Phase 6: how often (every N solves) to run hypothesizer.scan() in
# process. 0 disables auto-scan. Recommended: 10–25 once you have a
# steady solve rate.
PRU_AUTO_SCAN_EVERY_N=0

# Ollama HTTP endpoint (default local install listens on 11434).
OLLAMA_HOST=http://localhost:11434

# Ollama model used for natural-language parsing and explanation.
# Recommended: qwen2.5-math, llama3.1, mistral.
OLLAMA_MODEL=qwen2.5-math

# Whether the natural-language parser should call Ollama at all.
# If 'false', NL parsing falls back to raising an error; LaTeX and SymPy
# syntax still work.
OLLAMA_ENABLED=true

# Hard cap on a single tool invocation in seconds.
PRU_TOOL_TIMEOUT_S=20
