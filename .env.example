# PRU Math Engine — environment configuration

# Path to the SQLite database file. Relative paths resolve from the repo root.
PRU_DB_PATH=./data/pru_math.sqlite

# Ollama HTTP endpoint (default local install listens on 11434).
OLLAMA_HOST=http://localhost:11434

# Ollama model used for natural-language parsing and explanation.
# Recommended: qwen2.5-math, llama3.1, mistral.
OLLAMA_MODEL=qwen2.5-math

# Whether the natural-language parser should call Ollama at all.
# If 'false', NL parsing falls back to raising an error; LaTeX and SymPy
# syntax still work.
OLLAMA_ENABLED=true

# Hard cap on a single tool invocation in seconds.
PRU_TOOL_TIMEOUT_S=20
